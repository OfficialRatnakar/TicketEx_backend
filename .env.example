# Copy this file to .env for local development (never commit .env)

# Your Vercel frontend URL — comma-separated if multiple
FRONTEND_URL=https://your-app.vercel.app

# Third-party CSV that is CORS-blocked from the browser
CSV_SOURCE_URL=https://example.com/path/to/bookings.csv

# Long random string — generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace_with_a_long_random_string

# Gmail address + App Password (Settings → Security → 2FA → App passwords)
EMAIL_USER=you@gmail.com
EMAIL_PASS=xxxx xxxx xxxx xxxx

# MongoDB Atlas connection string (Cluster → Connect → Drivers)
MONGODB_URI=mongodb+srv://user:password@cluster0.xxxxx.mongodb.net/ticketex?retryWrites=true&w=majority

# Port — Render sets this automatically; 3000 is the local fallback
PORT=3000
