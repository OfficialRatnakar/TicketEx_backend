# Copy this file to .env for local development (never commit .env)

# Your Vercel frontend URL — comma-separated if you have multiple
# e.g. https://ticketex.vercel.app,http://127.0.0.1:5500
FRONTEND_URL=https://your-app.vercel.app

# The third-party CSV URL that is CORS-blocked from the browser
CSV_SOURCE_URL=https://example.com/path/to/bookings.csv

# Port — Render sets this automatically; 3000 is the local fallback
PORT=3000
